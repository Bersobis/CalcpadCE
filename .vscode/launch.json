{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Server: Run",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "bash",
            "runtimeArgs": [
                "${workspaceFolder}/Calcpad.Web/backend/scripts/restart-dev-server.sh"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Extension: Run",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad"
            ],
            "outFiles": [
                "${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad/out/**/*.js"
            ],
            "preLaunchTask": "Extension: Compile"
        },
        {
            "name": "Extension + Server: Run",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad"
            ],
            "outFiles": [
                "${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad/out/**/*.js"
            ],
            "preLaunchTask": "Extension + Server: Compile & Start"
        },
        {
            "name": "Extension + Bundled Server (Linux x64)",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad"
            ],
            "outFiles": [
                "${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad/out/**/*.js"
            ],
            "preLaunchTask": "Extension: Compile + Deploy Bundle"
        },
        {
            "name": "Extension + Bundled Server (Fedora x64)",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad"
            ],
            "outFiles": [
                "${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad/out/**/*.js"
            ],
            "preLaunchTask": "Extension: Compile + Deploy Bundle"
        },
        {
            "name": "Extension + Bundled Server (Debian x64)",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad"
            ],
            "outFiles": [
                "${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad/out/**/*.js"
            ],
            "preLaunchTask": "Extension: Compile + Deploy Bundle"
        },
        {
            "name": "Extension + Bundled Server (Windows x64)",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad"
            ],
            "outFiles": [
                "${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad/out/**/*.js"
            ],
            "preLaunchTask": "Extension: Compile + Deploy Bundle"
        }
    ]
}
