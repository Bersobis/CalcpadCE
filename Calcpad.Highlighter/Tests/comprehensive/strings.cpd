' String Variables and Functions
' String variables are implicitly created with the $ suffix

' Basic string variable assignment
#string s$ = trim$('  hello world  ')

' String function calls - 1 argument
n = len$(s$)
#string t$ = trim$(s$)
t$
#string lt$ = ltrim$('  left')
lt$
#string rt$ = rtrim$('right  ')
rt$
#string u$ = ucase$(s$)
u$
#string l$ = lcase$(u$)
l$
#string numStr$ = string$(42)
numStr$
numVal = val$('3.14')

' String function calls - 2 arguments
#string left2$ = left$(s$; 5)
#string right2$ = right$(s$; 5)
#string concatenated$ = concat$(left2$; right2$)
concatenated$
#string cmp$ = compare$(s$; 'hello world')

' String function calls - 3 arguments
#string mid3$ = mid$(s$; 1; 5)
#string replaced$ = replace$(s$; 'world'; 'earth')
pos = instr$(s$; 'world'; 0)

' Variadic string function
#string joined$ = concat$(s$; ' '; u$)
joined$

' String concatenation with +
#string greeting$ = concat$('Hello'; ' '; 'World')

' String equality check
s$ ≡ 'hello world'

' Using strings in control flow
#if s$
  'String is non-empty
#end if

' String in a loop
#string result$ = string$(0)
#for i = 1 : 3
  result$ = concat$(result$; string$(i))
#loop

' ===== STRING TABLES =====

' Table declaration with literal
#table tbl$ = ['a'; 'b' | 'c'; 'd']

' Table declaration with constructor
#table tbl2$ = table$(2; 3)

' Table element access
tbl$
tbl$(1; 1)
tbl$(2; 2)

' Table element write
tbl2$(1; 1) = 'hello'
tbl2$

' Split string into table
#string csv$ = 'a,b,c|d,e,f'
#table data$ = split$(csv$; '|'; ',')
data$
' Join table into string
#string back$ = join$(data$; '|'; ',')
#string flat$ = join$(data$; ',')

' Table in a loop
#table loopTable$ = table$(3; 1)
#for j = 1 : 3
  loopTable$(j; 1) = string$(j)
#loop
loopTable$
' Cross-type: string$ of matrix creates table
#table fromMatrix$ = string$([1; 2 | 3; 4])
fromMatrix$

' ===== STRING$ WITH UNITS =====

' Scalar with units
x = 5m
#string noUnits$ = string$(x)
noUnits$
#string withUnits$ = string$(x; 'true')
withUnits$
#string withoutUnits$ = string$(x; 'false')
withoutUnits$

' Case-insensitive boolean
#string upperCase$ = string$(x; 'TRUE')
upperCase$

' Vector to table with units
v = [1; 2; 3]m
#table vecNoUnits$ = string$(v)
vecNoUnits$
#table vecWithUnits$ = string$(v; 'true')
vecWithUnits$

' Matrix to table with units
M = [1; 2 | 3; 4]kN
#table matNoUnits$ = string$(M)
matNoUnits$
#table matWithUnits$ = string$(M; 'true')
matWithUnits$

' ===== ROW/COL TO STRING ARRAY =====

#table opts$ = ['Option A'; 'Option B'; 'Option C' | '1'; '2'; '3']
#string keys$ = rowToStringArray$(opts$; 1)
keys$
#string values$ = rowToStringArray$(opts$; 2)
values$
#string col1$ = colToStringArray$(opts$; 1)
col1$

' tableToStringArray$ — full table as nested JSON array
#string nested$ = tableToStringArray$(opts$)
nested$

' ===== TABLE MANIPULATION FUNCTIONS =====

#table src$ = ['a'; 'b'; 'c' | 'd'; 'e'; 'f' | 'g'; 'h'; 'i']

' rowT$ — extract single row
#table row2$ = rowT$(src$; 2)
row2$

' colT$ — extract single column
#table col3$ = colT$(src$; 3)
col3$

' extractRowsT$ — extract multiple rows
#table rows13$ = extractRowsT$(src$; [1; 3])
rows13$

' extractColsT$ — extract multiple columns
#table cols12$ = extractColsT$(src$; [1; 2])
cols12$

' subTable$ — extract rectangular region
#table sub$ = subTable$(src$; 1; 1; 2; 2)
sub$

' transposeT$ — swap rows and columns
#table transposed$ = transposeT$(src$)
transposed$

' augmentT$ — horizontal concatenation
#table left$ = ['x'; 'y' | 'z'; 'w']
#table wide$ = augmentT$(left$; left$)
wide$

' stackT$ — vertical concatenation
#table tall$ = stackT$(left$; left$)
tall$

' ===== TYPEOF$ FUNCTION =====

' Scalar value
scalarVar = 5m
#string typeScalar$ = typeOf$(scalarVar)
typeScalar$

' Vector
vecVar = [1; 2; 3]
#string typeVec$ = typeOf$(vecVar)
typeVec$

' Matrix
matVar = [1; 2 | 3; 4]
#string typeMat$ = typeOf$(matVar)
typeMat$

' String variable
#string strVar$ = 'hello'
#string typeStr$ = typeOf$(strVar$)
typeStr$

' Table variable
#table tblVar$ = ['a'; 'b']
#string typeTbl$ = typeOf$(tblVar$)
typeTbl$

' Expression (not a variable)
#string typeExpr$ = typeOf$(2 + 3)
typeExpr$