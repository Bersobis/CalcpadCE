f(x) = x^2 + 2*x + 1
g(x) = x^3 + 3*x + 3
h(x; y) = x^2 + y^2
x(t) = 2*t
y(t) = 3*t
a = 1
b = 10
c = 2
d = 5
const = 5
'Math Commands
$Root{f(x) = const @ x = a : b}
$Root{f(x) @ x = a : b}
$Find{f(x) @ x = a : b}
$Sup{f(x) @ x = a : b}
$Inf{f(x) @ x = a : b}
$Area{f(x) @ x = a : b}
$Sum{f(k) @ k = a : b}
$Sum{3*k @ k = a : b}
$Product{f(k) @ k = a : b}
$Repeat{f(k) @ k = a : b}
'Plot Commands
$Plot{f(x) @ x = a : b}
$Plot{x(t)|y(t) @ t = a : b}
$Plot{f(x) & g(x) @ x = a : b}
$Plot{f(t) & x(t)|y(t) @ t = a : b}
'Special Case where & is used in range. This is not acceptable syntax in most commands
$Map{h(x; y) @ x = a : b & y = c : d}
'Multiline Commands
w(x) = $While{x < 5; x = x + 1}
b(x) = $Block{y = x*5; x = x*y + 1}
i(x) = $Inline{y = x*5; x = x*y + 1}
'Error Testing
'Bad counter variable
$Root{f(x) = const @ 343x = a : b}
'Missing local variable in counter
$Root{f(y) = const @ x = a : b}
$Root{5*y*b = const @ x = a : b}