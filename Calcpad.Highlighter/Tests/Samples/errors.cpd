' File with various errors for testing

' Unbalanced parentheses
x = (1 + 2

' Unbalanced brackets
arr = [1; 2; 3

' Undefined variable usage
y = unknownVar * 2

' Invalid operator
z = 5 ++ 3

' Duplicate macro definition
#def myMacro$ = 10
#def myMacro$ = 20

' Macro name without $ suffix
#def badMacro = 5

' Unbalanced control block
#if x > 0
  result = 1
' Missing #end if

' Invalid include
#include

' Function parameter mismatch (if circleArea expects 1 param)
wrongCall = circleArea(1; 2; 3)

' ===== SECTION: Naming conflicts (CPD-32xx) =====

' Variable names CAN overlap with built-in functions (this is valid)
sin = 42
cos = 100
sqrt = 25

' Variable name conflicts with built-in constant (ERROR CPD-3207)
PI = 3.14
e = 2.71

' Variable name conflicts with keyword (ERROR CPD-3205)
if = 1
for = 2

' Variable name shadows built-in unit (WARNING CPD-3206)
m = 5
kg = 10
s = 2

' ===== SECTION: Undefined units (CPD-3310) =====

' Undefined unit (ERROR CPD-3310)
badUnitTest = 1badunit
anotherBad = 5xyz

' ===== SECTION: Type mismatches (CPD-3309) =====

' Type mismatch - n_rows expects matrix but gets scalar (WARNING CPD-3309)
scalarVal = 1
rowsOfScalar = n_rows(scalarVal)

' ===== SECTION: Function definition errors (CPD-3208) =====

' Function with no parameters (ERROR CPD-3208)
calc() = 43

' ===== SECTION: Invalid line continuation =====

' Line continuation with text after it (should error - _' is not valid continuation)
multiply(a; b; c) = a * b * c _' Three parameters

' Underscore not at end of line (should be parsed as undefined variable)
badLine(a; b; c) = a * b * c + _ + e

' ===== SECTION: Command block errors =====

' Valid command block function using if() and $Repeat - should have no errors
filterVec(v; val) = $Inline{result = vector(0); $Repeat{result = if(v.(i) > val; join(result; v.(i)); result) @ i = 1 : len(v)}; result}

' Unmatched opening brace in command block (ERROR CPD-3105)
unclosedBlock(x) = $Block{y = x * 2

' Complex command block with nested $Repeat
complexFunc(mat; threshold) = $Inline{total = 0; $Repeat{$Repeat{total = total + if(mat.(r; c) > threshold; mat.(r; c); 0) @ c = 1 : n_cols(mat)} @ r = 1 : n_rows(mat)}; total}

' Command block with $While - uses @ syntax for iteration variable
iterativeFunc(n) = $While{sum = 0; $Repeat{sum = sum + i @ i = 1 : n}; sum}

' ERROR: Using # directives inside command blocks is invalid (should use if(), $Repeat, etc.)
' This should produce an error for using #if inside $Inline
badDirectiveInBlock(x) = $Inline{#if x > 0; result = 1; #end if; result}

' ===== SECTION: Element access errors =====

' Function parameters do NOT support .i syntax - must use .(i)
' Should produce CPD-3301 with special hint message (ERROR expected)
badParamAccess(vect) = vect.1 + vect.2

' Same in command block context - param.i should error when called
badParamInBlock(vect) = $Inline{result = vect.1; result}
v_test = [1; 2; 3]
badParamInBlock(v_test)
