'Test macro parameter tokenization based on usage type

'Macro with comment parameter (header is used in comment text)
#def section$(header; value)
    '<h3>'header'</h3>'
    result = value * 2
#end def

'Macro call - header arg should tokenize as Comment, value as expression
section$(Section Title; 5 + 3)

'Inline macro with comment parameter
#def labeled$(label; x) = 'label' x * 2

'Call - label arg should tokenize as Comment
labeled$(My Label; 10)

'Macro where all params are used in code (no comment params)
#def calc$(a; b) = a + b * 2

'Call - both args should tokenize as expressions
calc$(5; 10)

'Regular variable for comparison
z = 5
