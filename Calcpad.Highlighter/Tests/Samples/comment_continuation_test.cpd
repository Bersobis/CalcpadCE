' Test that _ in comments does NOT cause line continuation
' This should be separate lines

' Test 1: cmt$('Code Comment Blocks') - the ' inside is NOT a comment
cmt$('Code Comment Blocks')

' Test 2: _ in comment should NOT continue
h = find([1; _'test
2; 3]; 2; 1)

' Test 3: Valid continuation with comment at start then _ at end
'Hello'h = 5','g = 6 _
','h = 7

' Test 4: Normal continuation with " _" at end
a = 1 + 2 + _
3 + 4

' Test 5: Line ending with ( but balanced - should NOT continue
x = sin(1)
y = 2

' Test 6: Line ending with ( unbalanced - should continue
z = sin(
1)
