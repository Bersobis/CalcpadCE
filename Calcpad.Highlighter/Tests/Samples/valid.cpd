' Valid Calcpad file with no errors

' Variables
a = 10
b = 20
c = a + b

' Function definition
square(x) = x^2
cube(x) = x^3

' Use built-in functions
sinValue = sin(45)
cosValue = cos(45)
sqrtValue = sqr(16)

' Macro definition
#def double$(n$) = n$ * 2

' Use macro
doubled = double$(c)

' Nested macro names - longer name takes precedence
' string$ expands to textval, ng$ expands to 1
' gstring$ should become gtextval (not gstri1)
#def string$ = 'testval'
#def ng$ = 1
macrotest = gstring$

' Control structures
#if a > 5
  "a is greater than 5"
#else
  "a is 5 or less"
#end if

' Proper nesting
nested = ((1 + 2) * (3 + 4))

' Line continuation (valid)
longCalc = 1 + 2 + 3 _
  + 4 + 5

' $Inline block with local variables (valid)
set(i; v; val) = $Inline{helperV = v; helperV.i = val; v = helperV}
