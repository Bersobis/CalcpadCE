'--- Keyword Arguments Test Suite ---

'=== MACRO KEYWORD ARGUMENTS ===

'--- Basic: single optional param ---
#def greet$(name$=World) = 'Hello, name$!
greet$()
greet$(Claude)
greet$(name$=Calcpad)

'--- Multiple params, all optional ---
#def box$(w$=10; h$=5; d$=3) = w$ * h$ * d$
box$()
box$(20)
box$(20; 8)
box$(20; 8; 4)

'--- Keyword overriding specific params ---
box$(d$=100)
box$(h$=50; d$=100)
box$(20; d$=7)

'--- Mixed required + optional ---
#def mix$(a$; b$=2; c$=3) = a$ + b$ + c$
mix$(10)
mix$(10; 20)
mix$(10; 20; 30)
mix$(10; c$=99)

'--- Nested macro calls as arguments ---
#def double$(x$=1) = x$ * 2
#def outer$(v$=5) = double$(v$)
outer$()
outer$(3)

'--- Expression as default value ---
#def calc$(x$=2+3) = x$
calc$()
calc$(100)

'=== CUSTOM FUNCTION KEYWORD ARGUMENTS ===

'--- Basic: single optional param ---
f(x = 5) = x^2
f()
f(3)
f(x = 10)

'--- Multiple params, all optional ---
vol(w = 1; h = 2; d = 3) = w * h * d
vol()
vol(10)
vol(10; 20)
vol(10; 20; 30)

'--- Keyword overriding specific params ---
vol(d = 100)
vol(h = 50; d = 100)
vol(10; d = 7)

'--- Mixed required + optional ---
g(a; b = 2; c = 3) = a + b + c
g(10)
g(10; 20)
g(10; 20; 30)
g(10; c = 99)

'--- Nested function calls as arguments ---
h(x = 1) = x * 2
k(v = 5) = h(v)
k()
k(3)

'--- Keyword with units ---
force(m = 1kg; a = 9.81m/s^2) = m * a
force()
force(5kg)
force(m = 10kg)
force(a = 3m/s^2)
force(m = 2kg; a = 5m/s^2)

'--- Multiple keyword-only calls ---
quad(a = 1; b = 0; c = 0; x = 1) = a*x^2 + b*x + c
quad()
quad(x = 2)
quad(a = 3; x = 2)
quad(a = 1; b = -2; c = 1; x = 1)

'--- Keyword args with conditional logic ---
clamp(val; lo = 0; hi = 100) = if(val < lo; lo; if(val > hi; hi; val))
clamp(50)
clamp(-5)
clamp(200)
clamp(200; hi = 150)
clamp(-5; lo = -10; hi = 10)
