#include %userprofile%\cei-engineering.com\Engineering Tools - Documents\CalcPad\Modules\Helper.cpd
h_Story = [0; 3; 6; 9; 12]
p_w = [10;14;23;34;23]*psf
Z = [0; 3; 6; 9; 12]
f(x) = p_w.(switch(x ≤ Z.1; 1; x ≥ take(1; last(Z; 1)); len(Z); take(1; last(find_lt(Z; x; 1); 1)) + 1))
hide$originpsf = 0psfunhide$
$Plot{f(x) & originpsf @ x = 0ft : take(1; last(Z; 1))}
h_Story
story_h_trib = vector(len(h_Story) + 1)
#for i = 1 : len(story_h_trib)
  'Iteration'i
  #if i ≡ 1
    story_h_trib.i = h_Story.i
  #else if i ≡ len(story_h_trib)
    story_h_trib.i = h_Story.(len(h_Story))
  #else
    story_h_trib.i = h_Story.i - (h_Story.i - h_Story.(i - 1))/2
  #end if
#loop
story_h_trib
hide$V_wall = vector(len(h_Story))unhide$
#for i = 1 : len(h_Story)
  i
  h_0 = story_h_trib.i
  h_1 = story_h_trib.(i + 1)
  h = h_1 - h_0
  V_wall.i = $Sum{f(y) @ y = h_0 : h_1}
#loop