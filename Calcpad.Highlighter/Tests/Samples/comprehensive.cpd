' --- 1. REAL NUMBERS AND BASIC MATH ---
a = 10
b = 3.14159
c = a + b
d = a - b
e = a * b
f = a/b
g = a^2
h = 5!

' --- 2. COMPLEX NUMBERS (use 1i not just i) ---
z1 = 3 + 2*1i
z2 = 5 - 4*1i
zSum = z1 + z2
zMag = abs(z1)
zPhase = phase(z1)
zReal = re(z1)
zImag = im(z1)

' --- 3. VECTORS ---
v1 = [1; 2; 3; 4; 5]
vLen = len(v1)
vSum = sum(v1)
vMin = min(v1)
vMax = max(v1)
vNorm = norm(v1)
v2 = [6; 7; 8; 9; 10]
vDot = dot(v1; v2)

' --- 4. MATRICES ---
M = [1; 2; 3 | 4; 5; 6 | 7; 8; 10]
I3 = identity(3)
nRows = n_rows(M)
nCols = n_cols(M)
mDet = det(M)
mTrace = trace(M)
mTransp = transp(M)

' --- 5. CUSTOM VARIABLES ---
myVar = 100
result = myVar*2
PI_custom = 3.14159265359

' --- 6. BUILT-IN CONSTANTS ---
piVal = π
eulerVal = e
goldenRatio = φ
gravityAccel = g

' --- 7. UNITS OF MEASUREMENT (SI) ---
length = 5*m
mass = 10*kg
time = 30*s
force = mass*9.81*m/s^2
area = 100*m^2
volume = 50*L
pressure = 101.325*kPa
energy = 500*J
power = 1000*W

' --- 8. IMPERIAL UNITS ---
lengthFt = 10*ft
lengthIn = 12*in
massLb = 100*lb
forceLbf = 50*lbf
pressurePsi = 14.7*psi

' --- 9. UNIT CONVERSION (using | separator) ---
lengthConverted = 1*m|cm

' --- 10. CUSTOM UNITS ---
.EUR = 1
.USD = 0.92
price = 100*.EUR
priceUSD = price/.USD

' --- 11. BUILT-IN FUNCTIONS ---

' Trigonometric
#deg
angle = 45
sinVal = sin(angle)
cosVal = cos(angle)
tanVal = tan(angle)
cscVal = csc(angle)
secVal = sec(angle)
cotVal = cot(angle)

' Inverse trigonometric
asinVal = asin(0.5)
acosVal = acos(0.5)
atanVal = atan(1)
atan2Val = atan2(1; 1)

' Hyperbolic
sinhVal = sinh(1)
coshVal = cosh(1)
tanhVal = tanh(1)

' Inverse hyperbolic
asinhVal = asinh(1)
acoshVal = acosh(2)
atanhVal = atanh(0.5)

' Logarithmic and exponential
logVal = log(100)
lnVal = ln(e)
log2Val = log_2(8)
expVal = exp(1)
sqrVal = sqr(16)
sqrtVal = sqrt(25)
cbrtVal = cbrt(27)
rootVal = root(16; 4)

' Rounding
roundVal = round(3.7)
floorVal = floor(3.7)
ceilVal = ceiling(3.7)
truncVal = trunc(-3.7)

' Integer functions
modVal = mod(17; 5)
gcdVal = gcd(12; 18)
lcmVal = lcm(4; 6)

' Complex functions
zAbs = abs(z1)
zRe = re(z1)
zIm = im(z1)
zPh = phase(z1)

' Aggregate functions
avgVal = average(1; 2; 3; 4; 5)
prodVal = product(1; 2; 3; 4)
srssVal = srss(3; 4)
sumsqVal = sumsq(1; 2; 3)
meanVal = mean(2; 8)

' Other functions
signVal = sign(-5)
randVal = random(100)

' --- 12. CUSTOM FUNCTIONS ---
square(x) = x^2
cube(x) = x^3
addTwo(x; y) = x + y
multiply(p; q; r) = p*q*r
hypotenuse(p; q) = sqr(p^2 + q^2)

' Use custom functions
sq = square(5)
cb = cube(3)
sum2 = addTwo(10; 20)
prod3 = multiply(2; 3; 4)
hyp = hypotenuse(3; 4)

' --- 13. CONDITIONAL FUNCTION ---
testX = 10
condResult = if(testX > 5; 100; 0)
switchResult = switch(testX < 5; 1; testX < 10; 2; testX < 15; 3; 99)

' --- 14. LOGICAL FUNCTIONS ---
notVal = not(0)
andVal = and(1; 1; 1)
orVal = or(0; 0; 1)
xorVal = xor(1; 0)

' --- 15. INTERPOLATION ---
interpLine = line(1.5; 0; 10; 20; 30)
interpSpline = spline(1.5; 0; 10; 20; 30)
takeVal = take(2; 10; 20; 30; 40)

' --- 16. VECTOR FUNCTIONS ---

' Creational
vRange = range(1; 10; 1)
vEmpty = vector(5)

' Structural
vSlice = slice(v1; 2; 4)
vFirst = first(v1; 3)
vLast = last(v1; 2)
vSize = size(v1)
vJoin = join(v1; v2)

' Data
vSorted = sort([5; 2; 8; 1; 9])
vRsorted = rsort([5; 2; 8; 1; 9])
vReversed = reverse([1; 2; 3])
vOrder = order([5; 2; 8; 1; 9])

' Search
searchVec = [10; 20; 30; 40; 50]
foundIdx = search(searchVec; 30; 1)
countVal = count(searchVec; 30; 1)
findIdx = find(searchVec; 30; 1)

' Math
vNorm1 = norm_1(v1)
vNorm2 = norm_2(v1)
vNormE = norm_e(v1)
vNormI = norm_i(v1)
vUnit = unit(v1)

' Vector products
v3a = [1; 0; 0]
v3b = [0; 1; 0]
crossProd = cross(v3a; v3b)
dotProd = dot(v3a; v3b)

' --- 17. MATRIX FUNCTIONS ---

' Creational
Mmat = matrix(3; 3)
Mident = identity(3)
Mdiag = diagonal(3; 1)
Mcol = column(3; 5)
Mupper = utriang(3)
Mlower = ltriang(3)
Msym = symmetric(3)

' Structural
Mrow = row(M; 1)
Mcol2 = col(M; 2)
Mdiag2vec = diag2vec(M)

' Math
mNorm = mnorm(M)
mNorm1 = mnorm_1(M)
mNormI = mnorm_i(M)
mCond = cond(M)
mRank = rank(M)
mInv = inverse(M)

' Matrix products
AA = [1; 2 | 3; 4]
BB = [5; 6 | 7; 8]
AB = AA*BB
hProd = hprod(AA; BB)

' Decompositions
luDecomp = lu(M)
qrDecomp = qr(M)

' Linear solve
bVec = [1; 2; 3]
xSol = lsolve(M; bVec)

' --- 18. INLINE MACRO DEFINITION ---
