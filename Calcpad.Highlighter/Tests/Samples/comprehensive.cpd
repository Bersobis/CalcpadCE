doubled = doubleIt$(15)

' --- 19. MULTILINE MACRO ---
#def tripleIt$(val$)
val$*3
#end def
tripled = tripleIt$(10)

' --- 20. COMMENTS ---
"This is a title comment"
'This is a text comment'

