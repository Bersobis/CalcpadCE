#repeat 3
  repeatCounter = repeatCounter + 1
#loop

' For loop
forTotal = 0
#for i = 1 : 5
  forTotal = forTotal + i
#loop

' While loop
whileCounter = 0
#while whileCounter < 3
  whileCounter = whileCounter + 1
#loop

' --- 23. OUTPUT CONTROL ---
#hide
hiddenVar = 999
#show

#val
valOnly = 42
#equ

#noc
nocVar = 100
#equ

#nosub
nosubVar = a + b
#varsub

' --- 24. TRIGONOMETRIC UNITS ---
