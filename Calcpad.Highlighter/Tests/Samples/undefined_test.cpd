"Test undefined identifier detection"

'Valid definitions
a = 5
b = 10
square(x) = x^2
cube(x) = x^3

'Valid usage
result1 = a + b
result2 = square(a)

'Undefined variable - should error CPD-3301
undefined_var_usage = undefined_var + 5

'Undefined function - should error CPD-3305
undefined_func_result = undefined_func(10)

'Undefined macro - should error CPD-3303
macro_result = undefined_macro$(a; b)

'Undefined unit - should error CPD-3310
distance = 100_undefined_unit

'Valid unit usage
length = 50_m
area = 25_m2

'Function with wrong parameter count - should error CPD-3302
wrong_param_count = square(a; b)

'Another undefined variable in expression
calc = a + undefined_x * b

'Undefined variable in function call
func_with_undef = square(undefined_y)

'Multiple undefined variables
multi_undef = undefined_a + undefined_b - undefined_c
