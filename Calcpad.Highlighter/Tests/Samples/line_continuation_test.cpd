"Test: Line Continuation in Strings"
'This tests that underscores inside strings are NOT treated as line continuations'

'Valid line continuation outside strings'
x = 5 + _
    10 + 15

'Line continuation in calculation'
result = 1.4*D + _
         1.6*S + _
         0.5*W

'String with underscore at end - should NOT break the line'
'<h5>LRFD (Section 2.3.1)</h5>'
'Case 1 -> 1.4D<br> _
'Case 3a -> 1.2D + 1.6S + 0.5W<br> _
'Case 3b -> 1.2D + 1.6S - 0.5W

'String with underscore in middle - should be part of string'
title = "Value_Name_Test"

'Function with line continuation'
multiply(a; b; c) = a * b * c _
                    + 100
